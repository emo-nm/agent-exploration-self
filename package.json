{
  "name": "eve-flue-smithers-demo",
  "private": true,
  "version": "0.0.0",
  "description": "Comparison monorepo for Eve and Flue product-agent frameworks, orchestrated by Smithers.",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=22.19.0"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "eval:durability": "pnpm --filter @demo/evals durability --",
    "check:caching": "pnpm --filter @demo/model check:caching"
  },
  "devDependencies": {
    "tsx": "^4.23.0",
    "turbo": "^2.5.0",
    "typescript": "^5.6.0"
  },
  "pnpm": {
    "patchedDependencies": {
      "@flue/runtime": "patches/@flue__runtime.patch"
    }
  }
}
