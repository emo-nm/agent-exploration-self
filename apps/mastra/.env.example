# --- model (BYO; not required for build/typecheck/tests) ---
OPENAI_API_KEY=your-api-key

# --- server ---
# Mastra serves on port 3003 (configured in src/mastra/index.ts).
# Health: GET /health (built-in) and GET /demo/health (custom, lists agents).

# --- persistence ---
# Unset -> in-memory repo (no DB needed). Set -> Drizzle/Postgres.
DATABASE_URL=

# --- failure injection (shared @demo/effects, handoff #18) ---
DEMO_FAIL_PUBLISH_ATTEMPTS=0
DEMO_CRASH_AFTER_EFFECT=false
