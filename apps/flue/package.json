{
  "name": "flue",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "generate:skill": "node scripts/generate-skill.mjs",
    "prebuild": "pnpm generate:skill",
    "build": "flue build --target node",
    "predev": "pnpm generate:skill",
    "dev": "flue dev --target node --port 3002",
    "start": "node dist/server.mjs",
    "pretypecheck": "pnpm generate:skill",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@demo/contracts": "workspace:*",
    "@demo/voice": "workspace:*",
    "@demo/domain": "workspace:*",
    "@demo/effects": "workspace:*",
    "@demo/persistence": "workspace:*",
    "@demo/prompts": "workspace:*",
    "@flue/runtime": "1.0.0-beta.9",
    "@flue/sdk": "1.0.0-beta.9",
    "drizzle-orm": "^0.36.0",
    "hono": "^4.6.0",
    "valibot": "^1.4.2"
  },
  "devDependencies": {
    "@flue/cli": "1.0.0-beta.9",
    "@types/node": "24.x",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": "24.x"
  }
}
